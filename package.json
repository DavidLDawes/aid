{
  "name": "starship-designer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ci": "pnpm install",
    "dev": "webpack serve --mode development",
    "build": "tsc -b && webpack --mode production",
    "lint": "eslint .",
    "preview": "http-server dist",
    "serve": "pnpm build && pnpm preview",
    "test": "jest",
    "test:ui": "jest --watch",
    "test:run": "jest --watchAll=false --coverage",
    "extractDB": "node scripts/extractDB.mjs",
    "preloadDB": "node scripts/preloadDB.mjs",
    "setInitialDB": "node scripts/setInitialDB.mjs",
    "flushDB": "node scripts/flushDB.mjs",
    "apply-feature": "node scripts/apply-feature.mjs",
    "start": "pnpm run dev"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.29.0",
    "@babel/preset-typescript": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ungap__structured-clone": "^1.2.0",
    "@ungap/structured-clone": "^1.3.2",
